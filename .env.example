# Supabase local database — Supabase CLI defaults
# host.docker.internal resolves to the host machine on Docker Desktop (Windows/Mac)
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:54322/postgres?sslmode=disable

# Ollama LLM provider — used by message parser for freeform messages
# OLLAMA_BASE_URL: base URL of the Ollama API
#   - Local Ollama: http://localhost:11434/v1 (default)
#   - Ollama Cloud: https://ollama.com/v1
# OLLAMA_API_KEY: leave empty for local (unauthenticated); set to your Ollama Cloud token for cloud
#   Note: this is separate from OPENAI_API_KEY above (which is used by Supabase Studio only)
# OLLAMA_MODEL: any model available in your Ollama instance (default: qwen2.5:3b)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=qwen2.5:3b

# Get this from: supabase status (look for "JWT secret")
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# graphql-api runtime tuning (all optional)
# ENV=production disables GraphQL Playground and introspection
# CORS_ALLOWED_ORIGINS: comma-separated, "*" allows any (dev default)
# MAX_BODY_BYTES: request body cap (default 1048576 = 1 MiB)
# RATE_LIMIT_RPS / RATE_LIMIT_BURST: per-IP token bucket (default 50 / 100)
ENV=development
CORS_ALLOWED_ORIGINS=*
MAX_BODY_BYTES=1048576
RATE_LIMIT_RPS=50
RATE_LIMIT_BURST=100

# Supabase Studio AI (optional — enables AI features in Studio UI)
OPENAI_API_KEY=

# SMS provider — only needed if auth.sms.twilio is enabled in supabase/config.toml
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=

# OAuth providers — only needed if the corresponding [auth.external.*] is enabled
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=

# OrioleDB/S3 — only needed if experimental.orioledb_version is set in supabase/config.toml
S3_HOST=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
